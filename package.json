{
  "name": "youtube-plus",
  "version": "1.0.0",
  "description": "YouTube Clone with WebSocket-powered live subscriber, like, and comment counts",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "setup": "node setup.js",
    "dev:client": "cd client && npm run dev",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:client\""
  },
  "keywords": [
    "youtube",
    "clone",
    "websocket",
    "socket.io",
    "real-time"
  ],
  "author": "Faiz",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "redis": "^4.6.13",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  }
}
